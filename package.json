{
  "name": "edu-system",
  "private": true,
  "version": "1.0.0",
  "description": "教务管理系统 - 小型培训机构教务管理工具",
  "author": "EduSystem",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:build:win": "vite build && electron-builder --win"
  },
  "dependencies": {
    "lowdb": "^7.0.1",
    "pinia": "^2.1.7",
    "sql.js": "^1.14.1",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.edusystem.app",
    "productName": "教务管理系统",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.education",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "x64ArchFiles": "x64",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  }
}
